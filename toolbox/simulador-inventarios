  document.getElementById('prodName').value = 'Aceite Motor 20W50 (lt)';
  document.getElementById('demandDay').value = '12';
  document.getElementById('demandStd').value = '3.5';
  document.getElementById('unitCost').value = '28000';
  document.getElementById('orderCost').value = '85000';
  document.getElementById('holdingPct').value = '25';
  document.getElementById('stockoutCost').value = '65000';
